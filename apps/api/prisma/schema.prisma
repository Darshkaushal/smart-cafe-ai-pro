generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum MenuCategory {
  COFFEE
  TEA
  MOCKTAIL
  SHAKE
  DESSERT
  SNACK
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum OrderStatus {
  PENDING
  PREPARING
  READY
  COMPLETED
  CANCELLED
}

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
}

model Admin {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Customer {
  id            String         @id @default(cuid())
  name          String
  email         String?
  phone         String?
  bookings      Booking[]
  orders        Order[]
  conversations Conversation[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([phone])
  @@index([email])
}

model MenuItem {
  id          String       @id @default(cuid())
  name        String
  slug        String       @unique
  description String       @db.Text
  category    MenuCategory
  price       Decimal      @db.Decimal(10, 2)
  tags        Json
  imageUrl    String?
  sweetness   Int          @default(2)
  temperature String       @default("medium")
  isAvailable Boolean      @default(true)
  orderItems  OrderItem[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Booking {
  id         String        @id @default(cuid())
  customerId String
  customer   Customer      @relation(fields: [customerId], references: [id], onDelete: Cascade)
  date       DateTime
  timeSlot   String
  guests     Int
  notes      String?       @db.Text
  status     BookingStatus @default(PENDING)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  @@index([date])
  @@index([status])
}

model Order {
  id          String      @id @default(cuid())
  customerId  String
  customer    Customer    @relation(fields: [customerId], references: [id], onDelete: Cascade)
  status      OrderStatus @default(PENDING)
  totalAmount Decimal     @db.Decimal(10, 2)
  pickupTime  String?
  items       OrderItem[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([createdAt])
  @@index([status])
}

model OrderItem {
  id         String   @id @default(cuid())
  orderId    String
  menuItemId String
  quantity   Int
  price      Decimal  @db.Decimal(10, 2)
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id])
}

model Conversation {
  id           String    @id @default(cuid())
  customerId   String?
  customer     Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  channel      String    @default("website")
  userLanguage String    @default("mixed")
  demandText   String    @db.Text
  messages     Message[]
  createdAt    DateTime  @default(now())

  @@index([createdAt])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           MessageRole
  content        String       @db.Text
  createdAt      DateTime     @default(now())
}

model DemandPrediction {
  id                String   @id @default(cuid())
  targetDate        DateTime @unique
  expectedOccupancy Int
  expectedBookings  Int
  confidence        Float
  modelVersion      String
  notes             String   @db.Text
  createdAt         DateTime @default(now())
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  subject   String
  message   String   @db.Text
  createdAt DateTime @default(now())
}
